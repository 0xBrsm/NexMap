{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nexmap-blueprint-v1",
  "title": "NexMap Blueprint",
  "description": "LLM-authored map blueprint that drives the mapgen compiler. Describes rooms, connections, entity placement intent, and theme — the creative layer that turns procedural geometry into human-quality maps.",
  "type": "object",
  "required": ["version", "meta", "rooms", "connections"],
  "additionalProperties": false,
  "properties": {

    "version": {
      "const": 1,
      "description": "Schema version. Always 1 for this revision."
    },

    "meta": {
      "type": "object",
      "description": "Map-level metadata and design intent.",
      "required": ["name", "theme", "gamemode"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "description": "Map name, e.g. 'The Cistern'. Used as the .bsp filename slug."
        },
        "author": {
          "type": "string",
          "description": "Attribution — 'NexMap LLM' or a human name."
        },
        "description": {
          "type": "string",
          "maxLength": 512,
          "description": "One-paragraph design summary. What makes this map interesting?"
        },
        "theme": {
          "type": "string",
          "enum": [
            "base",
            "medieval",
            "runic",
            "elder",
            "wizard",
            "metal",
            "custom"
          ],
          "description": "Visual theme. Drives texture set selection."
        },
        "custom_theme": {
          "type": "string",
          "description": "Free-form theme name when theme is 'custom'."
        },
        "gamemode": {
          "type": "string",
          "enum": ["deathmatch", "duel", "teamplay", "ffa"],
          "description": "Intended play mode. Affects entity budgets and spawn counts."
        },
        "player_count": {
          "type": "object",
          "description": "Target player count range.",
          "properties": {
            "min": { "type": "integer", "minimum": 2, "default": 2 },
            "max": { "type": "integer", "minimum": 2, "maximum": 16, "default": 8 }
          },
          "additionalProperties": false
        },
        "arena_size": {
          "type": "integer",
          "minimum": 1024,
          "maximum": 8192,
          "default": 3072,
          "description": "Bounding arena side length in Quake units."
        },
        "design_notes": {
          "type": "string",
          "description": "Free-form LLM reasoning about the design choices."
        }
      }
    },

    "rooms": {
      "type": "array",
      "minItems": 2,
      "maxItems": 32,
      "description": "The rooms that compose the map. Each room has spatial constraints and design intent.",
      "items": {
        "type": "object",
        "required": ["id", "role"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$",
            "description": "Unique room identifier, e.g. 'atrium', 'rl_room', 'lava_pit'."
          },
          "role": {
            "type": "string",
            "enum": [
              "arena",
              "atrium",
              "corridor_hub",
              "sniper_perch",
              "ambush",
              "control_point",
              "hazard",
              "transition",
              "spawn_area",
              "secret",
              "custom"
            ],
            "description": "Gameplay role. Informs shape, size, and entity decisions."
          },
          "label": {
            "type": "string",
            "maxLength": 64,
            "description": "Human-readable name, e.g. 'The Blood Arena'."
          },
          "size": {
            "type": "string",
            "enum": ["small", "medium", "large", "huge"],
            "default": "medium",
            "description": "Approximate footprint. small=256-384, medium=384-640, large=640-896, huge=896-1024."
          },
          "shape": {
            "type": "string",
            "enum": ["square", "wide", "tall_narrow", "l_shape", "any"],
            "default": "any",
            "description": "Preferred aspect ratio. 'wide' = 2:1+, 'tall_narrow' = 1:2+, 'l_shape' = future non-convex support."
          },
          "elevation": {
            "type": "string",
            "enum": ["ground", "low", "mid", "high", "varied"],
            "default": "ground",
            "description": "Floor elevation tier. ground=0, low=-128..-64, mid=64..192, high=256..384, varied=multi-level."
          },
          "ceiling": {
            "type": "string",
            "enum": ["low", "normal", "tall", "cavernous"],
            "default": "normal",
            "description": "Ceiling height intent. low=128, normal=192, tall=256, cavernous=320."
          },
          "hazard": {
            "type": "object",
            "description": "Optional hazard pool in this room.",
            "additionalProperties": false,
            "properties": {
              "type": {
                "type": "string",
                "enum": ["lava", "water", "slime"]
              },
              "coverage": {
                "type": "string",
                "enum": ["small", "medium", "large"],
                "default": "medium",
                "description": "Fraction of floor area. small=~15%, medium=~30%, large=~50%."
              }
            },
            "required": ["type"]
          },
          "items": {
            "type": "array",
            "description": "Entities the designer intends for this room. The compiler places them respecting spacing/collision rules.",
            "items": {
              "$ref": "#/$defs/item_placement"
            }
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Free-form tags for the LLM to annotate intent, e.g. ['high_traffic', 'risk_reward', 'vertical']."
          }
        }
      }
    },

    "connections": {
      "type": "array",
      "minItems": 1,
      "description": "Connections between rooms. The compiler builds corridors, stairs, and gap-fill geometry from these.",
      "items": {
        "type": "object",
        "required": ["from", "to", "type"],
        "additionalProperties": false,
        "properties": {
          "from": {
            "type": "string",
            "description": "Source room id."
          },
          "to": {
            "type": "string",
            "description": "Destination room id."
          },
          "type": {
            "type": "string",
            "enum": ["corridor", "wide_opening", "stairs", "drop", "teleporter", "door"],
            "description": "Connection type. corridor=standard 96-unit passage. wide_opening=wall removed between adjacent rooms. stairs=explicit staircase. drop=one-way fall. teleporter=non-adjacent link. door=triggered opening."
          },
          "bidirectional": {
            "type": "boolean",
            "default": true,
            "description": "Can players traverse both ways? False for drops and one-way teleporters."
          },
          "width": {
            "type": "string",
            "enum": ["narrow", "normal", "wide"],
            "default": "normal",
            "description": "Passage width. narrow=64, normal=96, wide=160."
          },
          "intent": {
            "type": "string",
            "maxLength": 128,
            "description": "Why this connection exists, e.g. 'escape route from RL room', 'main chokepoint'."
          }
        }
      }
    },

    "flow": {
      "type": "object",
      "description": "Optional high-level flow annotations that guide layout topology.",
      "additionalProperties": false,
      "properties": {
        "primary_loop": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Ordered list of room ids forming the main circulation loop. Good DM maps have at least one clear loop."
        },
        "secondary_loops": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "type": "string" }
          },
          "description": "Additional circulation loops for alternate routes."
        },
        "choke_points": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Room ids that are intentional bottlenecks."
        },
        "sightlines": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to"],
            "additionalProperties": false,
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "description": { "type": "string" }
            }
          },
          "description": "Intended long-range visibility between rooms."
        }
      }
    },

    "textures": {
      "type": "object",
      "description": "Optional per-room or global texture overrides. Falls back to theme defaults.",
      "additionalProperties": false,
      "properties": {
        "floor": { "type": "string" },
        "ceiling": { "type": "string" },
        "wall": { "type": "string" },
        "trim": { "type": "string" }
      }
    }
  },

  "$defs": {
    "item_placement": {
      "type": "object",
      "required": ["classname"],
      "additionalProperties": false,
      "properties": {
        "classname": {
          "type": "string",
          "enum": [
            "weapon_supershotgun",
            "weapon_nailgun",
            "weapon_supernailgun",
            "weapon_grenadelauncher",
            "weapon_rocketlauncher",
            "weapon_lightning",
            "item_shells",
            "item_spikes",
            "item_rockets",
            "item_cells",
            "item_health",
            "item_armor1",
            "item_armor2",
            "item_armorInv",
            "item_artifact_super_damage",
            "item_artifact_invulnerability",
            "item_artifact_invisibility",
            "info_player_deathmatch",
            "info_player_start",
            "info_teleport_destination",
            "light"
          ],
          "description": "Quake entity classname."
        },
        "placement": {
          "type": "string",
          "enum": ["center", "corner", "wall", "elevated", "hidden", "near_hazard", "any"],
          "default": "any",
          "description": "Placement hint within the room."
        },
        "intent": {
          "type": "string",
          "maxLength": 128,
          "description": "Why this item is here, e.g. 'risk-reward near lava', 'rewards map control'."
        },
        "count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 8,
          "default": 1,
          "description": "How many of this entity to place."
        }
      }
    }
  }
}
